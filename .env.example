# Copy this file to `.env` and fill in real values before running the app.
# Do NOT commit real secrets to version control.

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/ivy_db

# Server
PORT=3000
NODE_ENV=development
SERVER_URL=http://localhost:3000
APP_NAME=Ivy Server

# JWT
JWT_SECRET=changemechangemechangemechangeme
REFRESH_TOKEN_SECRET=changemechangemechangemechangeme
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# Frontend
FRONTEND_URL=http://localhost:4200

# SMTP (optional in development)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=no-reply@example.com

# Prometheus (optional)
PROMETHEUS_URL=http://localhost:9090
# Server
NODE_ENV=development
PORT=4300
SERVER_URL=http://localhost:4300

# Database
DATABASE_URL=postgres://express-boilerplate:express-boilerplate@localhost:5432/express-boilerplate

# JWT
JWT_SECRET=your-jwt-secret-min-32-chars
REFRESH_TOKEN_SECRET=your-refresh-token-secret-min-32-chars
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# Frontend
FRONTEND_URL=http://localhost:3000

# Prometheus
PROMETHEUS_URL=http://localhost:9090

# Email (Optional in development)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=no-reply@example.com

# App
APP_NAME=Ivy Server